# Public site URL — used for canonical links, sitemap, and Open Graph tags.
# Defaults to the production domain in code if unset.
NEXT_PUBLIC_SITE_URL=https://growviasphere.com

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable analytics.
NEXT_PUBLIC_GA4_ID=

# Google Search Console HTML tag verification code (the content value only, not the full meta tag).
NEXT_PUBLIC_GSC_VERIFICATION=

# --- Customer portal (Phase 2) ---

# Postgres connection string (Neon, Vercel Postgres, Supabase, or any standard
# Postgres instance all work — src/lib/db.ts uses @prisma/adapter-pg).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Name of the session cookie. Change only if you need to avoid a collision.
SESSION_COOKIE_NAME=gvs_session

# Resend API key for transactional email (OTP codes, password resets, welcome
# email, member support "Email Us" notifications). Leave blank to log emails to
# the console instead of sending (dev mode).
RESEND_API_KEY=
SUPPORT_EMAIL=support@growviasphere.com

# Twilio credentials for SMS OTP delivery. Not wired up yet (no account
# provisioned) — leave blank to log SMS to the console instead (dev mode).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
